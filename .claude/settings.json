{
  "$comment": "GearShow 하네스 훅 배선. 상세 정책은 .claude/skills/orchestrator/SKILL.md 참조.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/tools/hooks/enforce-worktree.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/tools/hooks/enforce-plan.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/tools/hooks/suggest-worktree.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/tools/hooks/verify-and-block.sh"
          }
        ]
      }
    ]
  }
}
